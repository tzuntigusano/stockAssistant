# ─────────────────────────────────────────────────────────────────────────
#  Stock Analyzer — variables de entorno
#  Copia este archivo a  backend/.env  y rellena lo que quieras.
#  TODO es opcional: la app arranca sin ninguna clave (con funciones limitadas).
#  Lo más fácil es usar el instalador (Instalar.ps1 en Windows, instalar.sh en Mac).
# ─────────────────────────────────────────────────────────────────────────

# --- IA en la nube: Gemini (Google AI) ---
# Redacta los análisis y controla el gráfico por chat. Nivel gratuito disponible.
# Consíguela en:  https://aistudio.google.com/apikey  → "Create API key"
GEMINI_API_KEY=
# Modelo por defecto (opcional). El recomendado es gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- IA local: Ollama (alternativa gratis y offline a Gemini) ---
# Instala Ollama (https://ollama.com), descarga un modelo (ej: ollama pull qwen3.6)
# y déjalo corriendo. La app lo usa como respaldo si no hay clave de Gemini.
OLLAMA_MODEL=qwen3.6:latest

# --- Precio en TIEMPO REAL: Finnhub ---
# Sin esto, el precio va con retraso (Yahoo). Nivel gratuito: ~60 llamadas/min.
# Regístrate y copia tu API key en:  https://finnhub.io/register
FINNHUB_API_KEY=

# --- Alertas al MÓVIL por Telegram (opcional) ---
# 1) Habla con @BotFather en Telegram, crea un bot y copia el token aquí.
# 2) Escríbele "hola" a tu bot, arranca la app y abre:
#      http://localhost:8000/api/telegram/detect
#    para ver tu chat_id, y pégalo abajo.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
